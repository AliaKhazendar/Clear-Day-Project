<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme using Material Components -->
    <style name="Theme.ClearDayApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- تخصيص الألوان هنا -->
        <item name="colorPrimary">@color/purple</item>
        <item name="colorPrimaryVariant">@color/magic_purple</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- تخصيص الألوان الثانوية -->
        <item name="colorSecondary">@color/teal_blue</item>
        <item name="colorSecondaryVariant">@color/dark_blue</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- تخصيص الـ Status bar color -->
        <item name="android:statusBarColor">@color/white</item>

        <!-- تخصيص خلفية النوافذ -->
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
    </style>

</resources>