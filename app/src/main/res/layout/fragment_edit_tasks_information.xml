<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <!-- Dialog Title -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/edit_task_information"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="20dp" />

    <!-- Title Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title"
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_title"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/enter_title"
        android:textColor="#1A1A2E"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="text"
        android:maxLines="1"
        android:imeOptions="actionNext" />

    <!-- Title Error Message -->
    <TextView
        android:id="@+id/tv_title_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_cannot_be_empty"
        android:textSize="12sp"
        android:textColor="#EF4444"
        android:fontFamily="sans-serif"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <!-- Description Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/description"
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_description"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="@string/enter_description"
        android:textColor="#1A1A2E"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:imeOptions="actionDone" />

    <!-- Description Error Message -->
    <TextView
        android:id="@+id/tv_description_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/description_cannot_be_empty"
        android:textSize="12sp"
        android:textColor="#EF4444"
        android:fontFamily="sans-serif"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="end">

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/cancel"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:backgroundTint="#A8ABAC"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginEnd="10dp"
            />

        <!-- Add Button -->
        <Button
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/edit"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/purple"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            />


    </LinearLayout>

    <TextView
        android:id="@+id/tvBeeSign"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="@string/bee"
        android:textSize="60sp"
        android:gravity="center"
        android:visibility="gone"
        />
    <TextView
        android:id="@+id/tvInfoMessage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="@string/invalid_request_to_edit"
        android:textSize="20sp"
        android:gravity="center"
        android:visibility="gone"
        />

</LinearLayout>