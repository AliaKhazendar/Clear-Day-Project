<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle"
        android:padding="10dp"
        android:src="@drawable/baseline_arrow_back_ios_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Task"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/txtTaskName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Name"
        android:textColor="#424040"
        android:textSize="16sp"
        android:layout_marginTop="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack"/>

    <EditText
        android:id="@+id/etTaskName"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@drawable/bg_input"
        android:hint="Mobile Application design"
        android:paddingStart="16dp"
        android:textColor="#3F51B5"
        app:layout_constraintTop_toBottomOf="@id/txtTaskName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="#424040"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etTaskName"
        app:layout_constraintStart_toStartOf="parent"/>

    <EditText
        android:id="@+id/etDate"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@drawable/bg_input"
        android:text="November 01, 2021"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start Time"
        android:textColor="#424040"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etDate"
        app:layout_constraintStart_toStartOf="parent"/>

    <EditText
        android:id="@+id/etStart"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@drawable/bg_input"
        android:text="9:30 am"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtStart"
        app:layout_constraintStart_toStartOf="@id/txtStart"
        app:layout_constraintEnd_toStartOf="@id/etEnd"
        android:layout_marginEnd="10dp"
        />

    <TextView
        android:id="@+id/txtEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="End Time"
        android:textColor="#424040"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/txtStart"
        app:layout_constraintStart_toStartOf="@id/etEnd"/>

    <EditText
        android:id="@+id/etEnd"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="@drawable/bg_input"
        android:text="3:30 pm"
        android:paddingStart="16dp"
        app:layout_constraintTop_toTopOf="@id/etStart"
        app:layout_constraintStart_toEndOf="@id/etStart"
        app:layout_constraintEnd_toEndOf="@id/etDate"
        app:layout_constraintWidth_percent="0.5"/>

    <TextView
        android:id="@+id/txtBoard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Board"
        android:textColor="#424040"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etStart"
        app:layout_constraintStart_toStartOf="parent"/>

        <Button
            android:id="@+id/btnUrgent"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Urgent"
            android:backgroundTint="@color/light_gray"
            app:layout_constraintTop_toBottomOf="@id/txtBoard"
            app:layout_constraintStart_toStartOf="@id/txtBoard"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toStartOf="@id/btnRunning"
            />

        <Button
            android:id="@+id/btnRunning"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Running"
            android:backgroundTint="@color/light_gray"
            app:layout_constraintTop_toBottomOf="@id/txtBoard"
            app:layout_constraintStart_toEndOf="@id/btnUrgent"
            android:layout_margin="16dp"
            app:layout_constraintEnd_toStartOf="@id/btnOngoing"
            />
    <Button
            android:id="@+id/btnOngoing"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Ongoing"
            android:backgroundTint="@color/light_gray"
            app:layout_constraintTop_toBottomOf="@id/txtBoard"
            app:layout_constraintStart_toEndOf="@id/btnRunning"
        app:layout_constraintEnd_toEndOf="@id/etDate"
            android:layout_margin="16dp"
            />




    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Save"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6C63FF"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/btnRunning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>