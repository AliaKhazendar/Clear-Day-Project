<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragments.onboard.FirstOnBoardFragment">

    <ImageView
        android:id="@+id/on_board_circle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:src="@drawable/image_on_board_circle"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@+id/on_board_person_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="70dp"
        android:src="@drawable/image_on_board_person_three"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/image_on_board_chat_tow"
        app:layout_constraintBottom_toTopOf="@+id/on_board_person_3"
        app:layout_constraintEnd_toStartOf="@+id/on_board_person_3"
        app:layout_constraintTop_toTopOf="@+id/on_board_person_3" />

    <ImageView
        android:id="@+id/on_board_person_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/image_on_board_person_one"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/on_board_person_3" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="60dp"
        android:src="@drawable/image_on_board_chat"
        app:layout_constraintBottom_toTopOf="@+id/on_board_person_2"
        app:layout_constraintStart_toStartOf="@+id/on_board_person_2"
        app:layout_constraintTop_toTopOf="@id/on_board_person_2" />

    <ImageView
        android:id="@+id/on_board_person_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="30dp"
        android:src="@drawable/image_on_board_person_tow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/on_board_person_2" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="80dp"
        android:src="@drawable/image_on_board_chat_tow"
        app:layout_constraintBottom_toTopOf="@+id/on_board_person_1"
        app:layout_constraintEnd_toEndOf="@+id/on_board_person_1"
        app:layout_constraintTop_toTopOf="@+id/on_board_person_1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/on_board_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:textAlignment="textStart"
        android:layout_marginHorizontal="30dp"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/on_board_clear_day_app"
            android:textColor="@color/purple"
            android:textSize="18sp"
            android:fontFamily="@font/roboto"
            android:fontWeight="500"
            android:textAlignment="textStart"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/on_board_message_one"
            android:textColor="@color/dark_blue"
            android:textSize="35sp"
            android:fontFamily="@font/roboto"
            android:fontWeight="600"
            android:textAlignment="textStart"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>